# ============================================================
# Job Agent — Environment Config
#
# 1. Copy this file:  copy .env.example .env   (Windows)
#                     cp .env.example .env     (macOS/Linux)
# 2. Get a Claude API key: https://console.anthropic.com
# 3. Paste your key below (required for scoring, tailoring, cover letters)
#
# Never commit .env — it is gitignored.
# ============================================================

# --- REQUIRED for AI stages (score, tailor, cover letter, --url) ---
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- OPTIONAL: Google (for Sheets tracking + Drive storage) ---
GOOGLE_CREDENTIALS_PATH=./data/google_credentials.json

# --- OPTIONAL: Gmail (for outreach drafts) ---
GMAIL_SENDER=your-email@gmail.com

# --- JOB SEARCH SETTINGS (edit these!) ---
# JOB_LOCATION: one place or a JSON list of places to search
# Use "Israel" alone for a broad country search, or add cities for wider coverage
JOB_LOCATION=["Israel", "Tel Aviv, Israel", "Haifa, Israel", "Jerusalem, Israel", "Beer Sheva, Israel", "Ramat Gan, Israel", "Herzliya, Israel", "Petah Tikva, Israel", "Netanya, Israel", "Rishon LeZion, Israel", "Ashdod, Israel", "Rehovot, Israel", "Akko, Israel", "Carmiel, Israel", "Kfar Saba, Israel", "Ra'anana, Israel", "Modi'in, Israel", "Ashkelon, Israel"]
JOB_COUNTRY=Israel
JOB_RADIUS_KM=200
JOB_SITE_LIST=["linkedin", "indeed", "glassdoor"]
MIN_MATCH_SCORE=70          # Only process jobs scoring above this (0-100)
MAX_JOBS_PER_RUN=20         # Max jobs to fetch per run
RESULTS_WANTED=50           # Jobs to fetch from each board before filtering

# --- OUTPUT SETTINGS ---
OUTPUT_DIR=./outputs
DB_PATH=./data/jobs.db
